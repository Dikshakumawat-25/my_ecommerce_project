<div class="min-h-screen bg-gray-50 p-6">
  <h1 class="text-3xl font-bold mb-6 text-gray-800 text-center">Users</h1>

  <div class="flex justify-end mb-4">
    <%= link_to "New User", new_user_path, class: "px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition duration-200" %>
  </div>

  <table class="w-full bg-white rounded-lg shadow-lg">
    <thead class="bg-gray-200">
      <tr>
        <th class="p-4 text-left">Name</th>
        <th class="p-4 text-left">Email</th>
        <th class="p-4 text-left">Role</th>
        <th class="p-4 text-center">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr class="border-b">
          <td class="p-4"><%= user.name %></td>
          <td class="p-4"><%= user.email %></td>
          <td class="p-4"><%= user.role.capitalize %></td>
          <td class="p-4 text-center flex justify-evenly">
            <%= link_to "Edit", edit_user_path(user), class: "px-4 py-2  bg-yellow-500 text-white rounded-lg hover:bg-yellow-600 transition duration-200 mr-2" %>
            <br><%= button_to  'Delete', user_path(user), method: :delete, data: { confirm: 'Are you sure?' }, class: "bg-yellow-500  text-white py-2 px-4 rounded-md hover:bg-yellow-600 transition" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
