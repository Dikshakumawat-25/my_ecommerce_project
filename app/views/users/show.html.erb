<div class="max-w-md mx-auto mt-10 bg-white shadow-lg rounded-lg p-8">
  <h1 class="text-2xl font-semibold text-gray-700 mb-4">User Details</h1>
  <div class="space-y-4">
    <div>
      <h2 class="text-sm font-medium text-gray-600">Name:</h2>
      <p class="text-lg text-gray-800"><%= @user.name %></p>
    </div>
    <div>
      <h2 class="text-sm font-medium text-gray-600">Email:</h2>
      <p class="text-lg text-gray-800"><%= @user.email %></p>
    </div>
    <div>
      <h2 class="text-sm font-medium text-gray-600">Role:</h2>
      <p class="text-lg text-gray-800 capitalize"><%= @user.role %></p>
    </div>
  </div>
  <div class="mt-6 flex space-x-4">
    <%= link_to 'Edit', edit_user_path(@user), class: 'text-white bg-yellow-500 hover:bg-yellow-600 px-4 py-2 rounded-md' %>
    <%= link_to 'Back to Users', users_path, class: 'text-white bg-gray-500 hover:bg-gray-600 px-4 py-2 rounded-md' %>
  </div>
</div>
